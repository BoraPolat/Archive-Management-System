<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SoftwareDesign.ManageFieldsPage"
             Title="Manage Fields"
             BackgroundColor="#F2F2F7">

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- Arka plan logo -->
        <Image Source="gau_logo.png"
               Aspect="AspectFit"
               Opacity="0.3"
               VerticalOptions="Center"
               HorizontalOptions="Center"
               Grid.RowSpan="4" />

        <!-- Header -->
        <Frame Grid.Row="0"
               Margin="40,30,40,10"
               Padding="20"
               BackgroundColor="#000E38"
               CornerRadius="5"
               HasShadow="True">
            <Frame.Shadow>
                <Shadow Brush="Black" Opacity="0.15" Radius="20" Offset="0,8" />
            </Frame.Shadow>

            <Grid ColumnSpacing="15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackLayout Grid.Column="0" Spacing="5">
                    <Label Text="⚙️ Field Management" 
                           FontSize="20" 
                           FontAttributes="Bold" 
                           TextColor="White"/>
                    <Label Text="Create and customize document fields"
                           FontSize="12"
                           TextColor="#BDC3C7" />
                </StackLayout>

                <Frame Grid.Column="1" Padding="12,8" BackgroundColor="#34C759" CornerRadius="6" HasShadow="False">
                    <StackLayout Spacing="1">
                        <Label Text="Total Fields" FontSize="9" TextColor="White" HorizontalOptions="Center"/>
                        <Label x:Name="TotalFieldsLabel" Text="0" FontSize="16" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
                    </StackLayout>
                </Frame>
            </Grid>
        </Frame>

        <!-- Add New Button -->
        <Button Grid.Row="1"
                Margin="40,0,40,10"
                Text="➕ Add New Field" 
                FontSize="14"
                FontAttributes="Bold"
                HeightRequest="45"
                CornerRadius="5"
                BackgroundColor="#34C759"
                TextColor="White"
                Clicked="OnAddNewFieldClicked"
                Shadow="{Shadow Brush=Black, Opacity=0.2, Radius=5, Offset='0,3'}"/>

        <!-- Fields List - KOMPAKT -->
        <Frame Grid.Row="2"
               Margin="40,0,40,10"
               Padding="5"
               BackgroundColor="White"
               CornerRadius="5"
               HasShadow="True">
            <Frame.Shadow>
                <Shadow Brush="Black" Opacity="0.1" Radius="15" Offset="0,5" />
            </Frame.Shadow>

            <ScrollView>
                <CollectionView x:Name="FieldsCollectionView" 
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <!-- KOMPAKT SATIR -->
                            <Frame Margin="2,1"
                                   Padding="10,8"
                                   BackgroundColor="#F8F9FA"
                                   CornerRadius="3"
                                   HasShadow="False"
                                   BorderColor="#E0E0E0">
                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">

                                    <!-- Bilgiler - TEK SATIR -->
                                    <StackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                                        <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="8">
                                            <Label Grid.Column="0"
                                                   Text="{Binding Display_Name}" 
                                                   FontSize="13" 
                                                   FontAttributes="Bold" 
                                                   TextColor="#000E38"
                                                   VerticalOptions="Center"/>
                                            <Frame Grid.Column="1"
                                                   Padding="5,2"
                                                   BackgroundColor="#007AFF"
                                                   CornerRadius="3"
                                                   HasShadow="False"
                                                   IsVisible="{Binding Is_System_Field}"
                                                   VerticalOptions="Center">
                                                <Label Text="SYSTEM" 
                                                       FontSize="8" 
                                                       FontAttributes="Bold" 
                                                       TextColor="White"/>
                                            </Frame>
                                        </Grid>
                                        <Label VerticalOptions="Center"
                                               FontSize="10"
                                               TextColor="#7F8C8D">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="ID: " TextColor="#95A5A6"/>
                                                    <Span Text="{Binding Field_Name}" TextColor="#7F8C8D"/>
                                                    <Span Text=" • " TextColor="#BDC3C7"/>
                                                    <Span Text="Type: " TextColor="#95A5A6"/>
                                                    <Span Text="{Binding Field_Type}" TextColor="#7F8C8D"/>
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                    </StackLayout>

                                    <BoxView Grid.Column="1" WidthRequest="1" BackgroundColor="#E0E0E0" Margin="5,0"/>

                                    <!-- Action Buttons - KOMPAKT -->
                                    <Grid Grid.Column="2" ColumnDefinitions="Auto,Auto,Auto" ColumnSpacing="5">
                                        <Button Grid.Column="0"
                                                Text="✏️"
                                                FontSize="14"
                                                WidthRequest="32"
                                                HeightRequest="32"
                                                CornerRadius="4"
                                                Padding="0"
                                                BackgroundColor="#007AFF"
                                                TextColor="White"
                                                Clicked="OnEditFieldClicked"/>
                                        <Button Grid.Column="1"
                                                Text="⚙️"
                                                FontSize="14"
                                                WidthRequest="32"
                                                HeightRequest="32"
                                                CornerRadius="4"
                                                Padding="0"
                                                BackgroundColor="#FF9500"
                                                TextColor="White"
                                                Clicked="OnEditOptionsClicked"/>
                                        <Button Grid.Column="2"
                                                Text="🗑️"
                                                FontSize="14"
                                                WidthRequest="32"
                                                HeightRequest="32"
                                                CornerRadius="4"
                                                Padding="0"
                                                BackgroundColor="#E74C3C"
                                                TextColor="White"
                                                Clicked="OnDeleteFieldClicked"/>
                                    </Grid>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </ScrollView>
        </Frame>

        <!-- Close Button -->
        <Button Grid.Row="3"
                Margin="40,0,40,30"
                Text="❌ Close" 
                FontSize="14"
                FontAttributes="Bold"
                HeightRequest="45"
                CornerRadius="5"
                BackgroundColor="#95A5A6"
                TextColor="White"
                Clicked="OnCloseClicked"
                Shadow="{Shadow Brush=Black, Opacity=0.2, Radius=5, Offset='0,3'}"/>

    </Grid>

</ContentPage>