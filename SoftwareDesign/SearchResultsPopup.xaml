<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SoftwareDesign.SearchResultsPopup"
             Title="Search Results"
             BackgroundColor="#F2F2F7">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Arka plan logo -->
        <Image Source="gau_logo.png"
               Aspect="AspectFit"
               Opacity="0.3"
               VerticalOptions="Center"
               HorizontalOptions="Center"
               Grid.RowSpan="3" />

        <!-- Başlık ve İstatistikler -->
        <Frame Grid.Row="0"
               Margin="40,30,40,10"
               Padding="20"
               BackgroundColor="#000E38"
               CornerRadius="5"
               HasShadow="True">
            <Frame.Shadow>
                <Shadow Brush="Black"
                        Opacity="0.15"
                        Radius="20"
                        Offset="0,8" />
            </Frame.Shadow>

            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackLayout Grid.Column="0" Spacing="5">
                    <Label Text="🔍 Search Results"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="White" />
                    <Label x:Name="SearchCriteriaLabel"
                           Text="Search criteria will appear here"
                           FontSize="12"
                           TextColor="#BDC3C7" />
                </StackLayout>

                <Frame Grid.Column="1"
                       Padding="15,10"
                       BackgroundColor="#34C759"
                       CornerRadius="8"
                       HasShadow="False"
                       VerticalOptions="Center">
                    <StackLayout Spacing="2">
                        <Label Text="Results Found"
                               FontSize="10"
                               TextColor="White"
                               HorizontalOptions="Center" />
                        <Label x:Name="ResultCountLabel"
                               Text="0"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="Center" />
                    </StackLayout>
                </Frame>
            </Grid>
        </Frame>

        <!-- Sonuçlar Grid/ScrollView -->
        <Frame Grid.Row="1"
               Margin="40,0,40,10"
               Padding="0"
               BackgroundColor="White"
               CornerRadius="5"
               HasShadow="True">
            <Frame.Shadow>
                <Shadow Brush="Black"
                        Opacity="0.1"
                        Radius="15"
                        Offset="0,5" />
            </Frame.Shadow>

            <Grid>
                <!-- Sonuçlar varsa CollectionView -->
                <CollectionView x:Name="ResultsCollectionView"
                                SelectionMode="Single"
                                SelectionChanged="OnResultSelected">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Margin="5,2"
               Padding="12,8"
               BackgroundColor="#F8F9FA"
               CornerRadius="3"
               HasShadow="False"
               BorderColor="#E0E0E0">
                                <Label Text="{Binding FullDetails}"
                   FontSize="12"
                   TextColor="#000000"
                   LineBreakMode="WordWrap" />
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Sonuç bulunamadıysa -->
                <StackLayout x:Name="NoResultsView"
                             IsVisible="False"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="15">
                    <Label Text="🔍"
                           FontSize="60"
                           HorizontalOptions="Center" />
                    <Label Text="No Results Found"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#7F8C8D"
                           HorizontalOptions="Center" />
                    <Label Text="Try adjusting your search criteria"
                           FontSize="14"
                           TextColor="#95A5A6"
                           HorizontalOptions="Center" />
                </StackLayout>
            </Grid>
        </Frame>

        <!-- Alt Butonlar -->
        <Grid Grid.Row="2" 
              Padding="40,10,40,30"
              ColumnSpacing="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Text="🔄 New Search"
                    FontSize="14"
                    FontAttributes="Bold"
                    HeightRequest="45"
                    CornerRadius="5"
                    BackgroundColor="#3498DB"
                    TextColor="White"
                    Clicked="OnNewSearchClicked"
                    Shadow="{Shadow Brush=Black, Opacity=0.2, Radius=5, Offset='0,3'}" />

            <Button Grid.Column="1"
                    Text="❌ Close"
                    FontSize="14"
                    FontAttributes="Bold"
                    HeightRequest="45"
                    CornerRadius="5"
                    BackgroundColor="#E74C3C"
                    TextColor="White"
                    Clicked="OnCloseClicked"
                    Shadow="{Shadow Brush=Black, Opacity=0.2, Radius=5, Offset='0,3'}" />
        </Grid>
    </Grid>
</ContentPage>